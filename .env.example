# Copy to .env and edit. Used by docker compose and one-click deploys.

# Mock = canned responses (default, no API key needed). Live = real Claude calls.
A2A_MODE=mock

# Required only when A2A_MODE=live
ANTHROPIC_API_KEY=

# Optional. Format: caller1=key1,caller2=key2 (commas separate, no spaces around =).
# If unset, the server accepts unauthenticated requests — fine for local dev,
# never OK in production.
A2A_API_KEYS=

# Per-caller requests per minute (default 30)
A2A_RATE_LIMIT=30

# Host port to expose the server on
A2A_PORT=8000

# Claude model used in live mode
A2A_MODEL=claude-sonnet-4-5-20250929
